{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "aniket-magadum/laravel-log-lens",
    "description": "A powerful Laravel log viewer and analyzer package.",
    "type": "library",
    "keywords": [
        "laravel",
        "log",
        "log-viewer",
        "log-lens",
        "debugging"
    ],
    "homepage": "https://github.com/aniket-magadum/laravel-log-lens",
    "license": "MIT",
    "authors": [
        {
            "name": "Aniket Magadum",
            "email": "aniketmagadum77@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/routing": "^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "AniketMagadum\\LogLens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AniketMagadum\\LogLens\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AniketMagadum\\LogLens\\LogLensServiceProvider"
            ],
            "aliases": {
                "LogLens": "AniketMagadum\\LogLens\\Facades\\LogLens"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=256M"
    }
}
